# Copy to .env and fill in. The backend loads this automatically (dotenv).
# Required for the "Auto-Fill with AI" job-summary feature.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the server port (defaults to 3000).
# PORT=3000

# AWS credentials/region used for DynamoDB, S3, and identity verification
# (Rekognition CompareFaces + Textract AnalyzeID). Omit the two key vars if
# you're running on an EC2/ECS/Lambda role that already has these permissions.
# AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
